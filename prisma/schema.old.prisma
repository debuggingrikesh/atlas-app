generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────
// IndustryTemplate
// ──────────────────────────────────────────

model IndustryTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  businesses Business[]
}

// ──────────────────────────────────────────
// Business (Tenant)
// ──────────────────────────────────────────

model Business {
  id                 String    @id @default(cuid())
  name               String
  slug               String    @unique
  industryTemplateId String
  description        String?
  logoUrl            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  version            Int       @default(1)
  deletedAt          DateTime?

  industryTemplate   IndustryTemplate       @relation(fields: [industryTemplateId], references: [id])
  branches           Branch[]
  members            BusinessMember[]
  roles              Role[]
  invitations        Invitation[]
  notifications      Notification[]
  reputationSettings ReputationSettings[]
  reviewCampaigns    ReviewCampaign[]
  reviewRequests     ReviewRequest[]
  customerFeedback   CustomerFeedback[]
  featureUsage       BusinessFeatureUsage[]
  aiSettings         BusinessAISettings?
  analyses           FeedbackAnalysis[]
  aiUsageLogs        AIUsageLog[]
  businessInsights   BusinessInsight[]
  subscription       BusinessSubscription?
  upgradeRequests    UpgradeRequest[]

  @@index([industryTemplateId])
}

// ──────────────────────────────────────────
// Branch
// ──────────────────────────────────────────

model Branch {
  id         String   @id @default(cuid())
  name       String
  businessId String
  address    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  version    Int      @default(1)

  business           Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  reputationSettings ReputationSettings[]
  reviewCampaigns    ReviewCampaign[]
  reviewRequests     ReviewRequest[]
  customerFeedback   CustomerFeedback[]

  @@index([businessId])
}

// ──────────────────────────────────────────
// UserProfile
// ──────────────────────────────────────────

model UserProfile {
  id                    String    @id
  email                 String    @unique
  fullName              String?
  avatarUrl             String?
  onboardingStep        Int       @default(1)
  onboardingCompletedAt DateTime?
  onboardingData        Json?
  isActive              Boolean      @default(true)
  platformRole          PlatformRole @default(NONE)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime  @updatedAt

  memberships     BusinessMember[]
  notifications   Notification[]
  upgradeRequests UpgradeRequest[]
}

// ──────────────────────────────────────────
// BusinessMember (join table)
// ──────────────────────────────────────────
//
// TRANSITION STATE:
//   role   — legacy MemberRole enum column (kept for backward compatibility)
//   roleId — new RBAC FK to Role (nullable until all members are backfilled)
//
// Both columns are written during the dual-write transition phase.
// MemberRole enum and the role column will be removed in a future migration
// once the RBAC system is fully verified in production.
// ──────────────────────────────────────────

model BusinessMember {
  id         String     @id @default(cuid())
  userId     String
  businessId String
  role       MemberRole @default(MEMBER) // legacy — kept for backward compatibility
  roleId     String? // RBAC FK — nullable during transition
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  version    Int        @default(1)

  user     UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  rbacRole Role?       @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
  @@index([roleId])
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum PlatformRole {
  NONE
  CEO
  PLATFORM_ADMIN @map("SUPER_ADMIN")
  FINANCE
  SUPPORT
  ANALYST
}

// ──────────────────────────────────────────
// AuditLog
// ──────────────────────────────────────────

model AuditEvent {
  id               String   @id @default(cuid())
  occurredAt       DateTime @default(now())

  action           String
  resourceType     String
  resourceId       String?

  actorType        String   @default("USER")
  actorUserId      String?
  actorRole        String?

  businessId       String?
  tenantId         String?

  requestId        String?
  sourceService    String   @default("atlas-app")
  severity         String   @default("INFO")

  summary          String
  metadata         Json?

  previousState    Json?
  newState         Json?

  ipAddressHash    String?
  userAgentSummary String?

  @@index([action, resourceType])
  @@index([actorUserId])
  @@index([businessId])
  @@index([occurredAt])
  @@index([requestId])
  @@map("AuditLog")
}

// ──────────────────────────────────────────
// RBAC: Role
// ──────────────────────────────────────────
//
// Roles are scoped to a Business. Every business gets three system roles
// (OWNER, ADMIN, MEMBER) created automatically on business creation.
// isSystem = true marks these as non-deletable system defaults.
// ──────────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  name        String
  businessId  String
  isSystem    Boolean  @default(false)
  isDefault   Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  members     BusinessMember[]
  invitations Invitation[]

  @@unique([businessId, name])
  @@index([businessId])
}

// ──────────────────────────────────────────
// RBAC: Permission
// ──────────────────────────────────────────
//
// Global permission registry. Keys follow resource.action format.
// category groups related permissions (e.g. "business", "member", "branch").
// ──────────────────────────────────────────

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  description String?
  category    String?

  roles RolePermission[]
}

// ──────────────────────────────────────────
// RBAC: RolePermission (join table)
// ──────────────────────────────────────────

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// ──────────────────────────────────────────
// Invitation
// ──────────────────────────────────────────

model Invitation {
  id         String           @id @default(cuid())
  businessId String
  email      String
  roleId     String
  tokenHash  String           @unique
  status     InvitationStatus @default(PENDING)
  metadata   Json?
  expiresAt  DateTime
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  role     Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([businessId, email])
  @@index([tokenHash])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

// ──────────────────────────────────────────
// Notification
// ──────────────────────────────────────────

model Notification {
  id String @id @default(cuid())

  userId     String
  businessId String

  type    String
  title   String
  message String

  metadata Json?

  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([businessId])
  @@index([createdAt])
  @@index([userId, readAt])
}

// ──────────────────────────────────────────
// Reputation: ReputationSettings
// ──────────────────────────────────────────

model ReputationSettings {
  id                   String   @id @default(cuid())
  businessId           String
  branchId             String? // Optional for branch-level overrides
  googleRedirectRating Int      @default(4)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([businessId, branchId])
  @@index([businessId])
}

// ──────────────────────────────────────────
// Reputation: ReviewCampaign
// ──────────────────────────────────────────

model ReviewCampaign {
  id         String   @id @default(cuid())
  businessId String
  branchId   String?
  name       String
  status          String   @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED
  googleReviewUrl String?
  publicId        String   @unique @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch?         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  requests ReviewRequest[]

  @@index([businessId])
}

// ──────────────────────────────────────────
// Reputation: ReviewRequest
// ──────────────────────────────────────────

model ReviewRequest {
  id            String   @id @default(cuid())
  businessId    String
  branchId      String?
  campaignId    String
  customerName  String?
  customerEmail String?
  customerPhone String?
  token         String   @unique
  status        String   @default("PENDING") // PENDING, OPENED, COMPLETED
  source        String   @default("MANUAL")  // MANUAL, WHATSAPP, QR, EMAIL
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch?           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  campaign ReviewCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  feedback CustomerFeedback?

  @@index([businessId])
  @@index([campaignId])
}

// ──────────────────────────────────────────
// Reputation: CustomerFeedback
// ──────────────────────────────────────────

model CustomerFeedback {
  id            String   @id @default(cuid())
  businessId    String
  branchId      String?
  requestId     String   @unique
  rating        Int
  comment       String?
  customerName  String?
  customerEmail String?
  customerPhone String?
  status        String   @default("UNREAD") // UNREAD, REVIEWED, RESOLVED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch   Branch?       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  request  ReviewRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  analyses FeedbackAnalysis[]

  @@index([businessId])
}

// ──────────────────────────────────────────
// BusinessFeatureUsage
// ──────────────────────────────────────────

model BusinessFeatureUsage {
  id         String   @id @default(cuid())
  businessId String
  feature    String // e.g., "REPUTATION_REVIEW_REQUESTS"
  count      Int      @default(0)
  limit      Int // e.g., 6 for FREE plan
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, feature])
  @@index([businessId])
}

// ──────────────────────────────────────────
// AI Models
// ──────────────────────────────────────────

model BusinessAISettings {
  id                 String   @id @default(cuid())
  businessId         String   @unique
  tone               String   @default("Professional")
  brandDescription   String?
  preferredLanguage  String   @default("English")
  customInstructions String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model FeedbackAnalysis {
  id            String   @id @default(cuid())
  businessId    String
  feedbackId    String
  analysisData  Json     // Replaces generatedText string, structured analysis
  status        String   @default("DRAFT") // DRAFT, APPROVED, COPIED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  feedback CustomerFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([feedbackId])
  @@map("AIResponse") // Map to existing table to prevent dropping existing records during migration
}

model AIUsageLog {
  id           String   @id @default(cuid())
  businessId   String
  model        String
  inputTokens  Int?
  outputTokens Int?
  createdAt    DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model BusinessInsight {
  id                 String   @id @default(cuid())
  businessId         String
  overallSentiment   String
  topComplaints      Json?
  topPraise          Json?
  recommendedActions Json?
  reputationTrend    String?
  createdAt          DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

// ──────────────────────────────────────────
// Billing & Subscriptions
// ──────────────────────────────────────────

model Plan {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique // FREE, PRO
  price     Float    @default(0)
  currency  String   @default("USD")
  interval  String   @default("month")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  features       PlanFeature[]
  subscriptions  BusinessSubscription[]
  upgradeRequests UpgradeRequest[]
}

model PlanFeature {
  id         String   @id @default(cuid())
  planId     String
  featureKey String
  limit      Int      @default(-1) // -1 for unlimited
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@index([planId])
}

model BusinessSubscription {
  id         String    @id @default(cuid())
  businessId String    @unique
  planId     String
  status     String    @default("ACTIVE") // ACTIVE, CANCELLED, EXPIRED
  startedAt  DateTime  @default(now())
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan     Plan     @relation(fields: [planId], references: [id])

  @@index([businessId])
  @@index([planId])
}

enum UpgradeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model UpgradeRequest {
  id              String               @id @default(cuid())
  businessId      String
  requestedPlanId String
  requestedBy     String
  status          UpgradeRequestStatus @default(PENDING)
  note            String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  requestedPlan Plan        @relation(fields: [requestedPlanId], references: [id])
  requester     UserProfile @relation(fields: [requestedBy], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([requestedPlanId])
  @@index([requestedBy])
}

// ──────────────────────────────────────────
// Operational Metrics
// ──────────────────────────────────────────

