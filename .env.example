# ─── Supabase ───
# Must be set in Vercel Environment Variables
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Supabase Admin (SERVER-ONLY — NEVER expose to client) ───
# Used only for server-side administrative operations (e.g., deleting orphaned auth users).
# NEVER prefix with NEXT_PUBLIC_. NEVER import in client components.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Database (Supabase PostgreSQL) ───
# Must be set in Vercel Environment Variables.
# DATABASE_URL should use the PgBouncer/Pooling port (usually 6543) and include ?pgbouncer=true
# DIRECT_URL should use the direct port (usually 5432)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ─── App ───
# Must be set in Vercel to your production domain (e.g. https://yourdomain.com).
# DO NOT include a trailing slash!
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email Configuration (Resend) ───
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM_ADDRESS=noreply@projectatlas.app

# ─── AI Integration ───
# Required for AI generation features in the reputation module
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Rate Limiting (Upstash Redis) ───
# Required for distributed rate limiting in production.
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

INTERNAL_INTEGRITY_SECRET=

# ─── Turnstile CAPTCHA ───
# Required for public review forms.
# For local development ONLY, you may use the Cloudflare test secret: 1x0000000000000000000000000000000AA
# NEVER use test credentials in staging or production.
TURNSTILE_SECRET_KEY=
