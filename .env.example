# ====================================================
# 1. APPLICATION-RUNTIME REQUIRED
# ====================================================
# Variables without which the application cannot operate safely.

# ─── Supabase Admin (SERVER-ONLY — NEVER expose to client) ───
# Used only for server-side administrative operations (e.g., deleting orphaned auth users).
SUPABASE_SERVICE_ROLE_KEY=

# ─── Database (Supabase PostgreSQL) ───
# DATABASE_URL should use the PgBouncer/Pooling port (usually 6543) and include ?pgbouncer=true
DATABASE_URL=

# ====================================================
# 2. BUILD/TOOLING REQUIRED
# ====================================================
# Variables used by build systems and CLI tools (e.g., Prisma migrations).

# DIRECT_URL should use the direct port (usually 5432) for Prisma tooling.
DIRECT_URL=

# ====================================================
# 3. FEATURE-REQUIRED VARIABLES
# ====================================================
# Variables required only when a specific integration or feature is enabled.

# ─── Email Configuration (Resend) ───
# Required for invitation email workflows. If missing, invitations will fail.
RESEND_API_KEY=

# ─── AI Integration ───
# Required for AI generation features in the reputation module
GEMINI_API_KEY=

# ─── Rate Limiting (Upstash Redis) ───
# Required for protecting production workflows (auth, public reviews) from abuse.
# Without these, the application will fail closed and deny requests.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Turnstile CAPTCHA ───
# Required for public review forms.
# For local development ONLY, you may use the Cloudflare test secret: 1x0000000000000000000000000000000AA
# NEVER use test credentials in staging or production.
TURNSTILE_SECRET_KEY=

# ─── Internal API Authentication ───
# Required for HQ to securely access App data.
HQ_INTERNAL_API_SECRET=

# ====================================================
# 3. OPTIONAL VARIABLES
# ====================================================
# Variables where absence has an intentionally supported and secure behavior.

# Optional "From" address for Resend.
EMAIL_FROM_ADDRESS=

# Optional previous secret for smooth rotation of internal auth.
HQ_INTERNAL_API_SECRET_PREVIOUS=

# Integrations and metrics options
ENABLE_SENTRY=
SENTRY_DSN=
METRICS_ENABLED=
METRICS_RETENTION_DAYS=
METRICS_FLUSH_INTERVAL_MS=
INTERNAL_INTEGRITY_SECRET=

# ====================================================
# 4. PUBLIC VARIABLES
# ====================================================
# Only variables intentionally exposed to browser code.

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── App ───
# DO NOT include a trailing slash!
NEXT_PUBLIC_APP_URL=

# ─── Turnstile ───
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ─── Observability ───
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_APP_ENV=
NEXT_PUBLIC_RELEASE_VERSION=
